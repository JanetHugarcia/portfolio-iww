{
  "name": "portfolio-iww",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "clean": "rm -rf dist",
    "build:html": "pug src/templates/index.pug --out dist --pretty",
    "build:css": "sass src/styles/main.scss dist/css/main.css --style=compressed",
    "copy:assets": "cpy \"public/**/*\" dist",
    "build": "pnpm run clean && pnpm run build:html && pnpm run build:css && pnpm run copy:assets",
    "watch:html": "pug src/templates/index.pug --out dist --watch",
    "watch:css": "sass --watch src/styles/main.scss:dist/css/main.css",
    "serve": "serve dist -l 3000",
    "dev": "pnpm run build && concurrently -k \"pnpm run watch:html\" \"pnpm run watch:css\" \"pnpm run serve\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.1.3",
      "onFail": "download"
    }
  },
  "type": "module",
  "devDependencies": {
    "@rsbuild/core": "^2.0.15",
    "@rsbuild/plugin-sass": "^1.5.3",
    "concurrently": "^10.0.3",
    "cpy-cli": "^7.0.0",
    "pug": "^3.0.4",
    "pug-cli": "1.0.0-alpha6",
    "sass": "^1.101.0",
    "serve": "^14.2.6"
  }
}
